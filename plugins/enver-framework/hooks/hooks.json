{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/sunucu-koruma.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/git-gizlilik-koruma.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/veri-koruma.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/kasa-koruma.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/tam-yetki.py\"" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/veri-koruma.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/kasa-koruma.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/tam-yetki.py\"" }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/kasa-koruma.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/tam-yetki.py\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/iz-kontrol.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/yazim-kontrol.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/oturum-kayit.py\"" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/oturum-kayit.py\"" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/oturum-acilis.py\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/kalite-kapisi.py\"" }
        ]
      }
    ]
  }
}

# ayni adli klasorler de dislaniyordu - ornek: scripts/kasa/ (kasa motorunun
# kendi kaynak kodu), ki onun git'te olmasi gerekir.
/vault/
/kasa/
*.vault
.env
.env.*
credentials*
*credentials*
*.pem
*.key
*.p12
*_secret*
*_sifre*
sifreler*


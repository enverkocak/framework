# CALISMA VE ARSIV ALANLARI
# ============================================
/_calisma/
/_arsiv/
/gunluk/

# ============================================
# GECICI DOSYALAR
# ============================================
*.tmp
*.temp
*.log
*.bak
*.swp
*~

# ============================================

# ============================================
Thumbs.db
Desktop.ini
.DS_Store

# ============================================
# BAGIMLILIKLAR VE URETIM CIKTILARI
# ============================================
node_modules/
vendor/
__pycache__/
*.pyc
dist/
build/

# Tarayici otomasyonu ciktilari - ekran goruntusu ve sayfa dokumu
.playwright-mcp/

